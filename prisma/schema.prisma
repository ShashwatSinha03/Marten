generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth (NextAuth.js) ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String           @id @default(cuid())
  name          String?
  email         String?          @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  accounts       Account[]
  sessions       Session[]
  investigations Investigation[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Application ────────────────────────────────────────────────────

model Investigation {
  id            String   @id @default(cuid())
  url           String
  normalizedUrl String
  depth         String   // "quick" | "standard"
  status        String   @default("pending")
  // "pending" | "url_validating" | "collecting_evidence" | "building_graph"
  // | "investigating" | "generating_report" | "complete" | "failed" | "aborted"
  progress      Float    @default(0) // 0.0 – 1.0
  error         String?
  errorCode     String?
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  metadata      Json?    // browser user-agent, viewport, timing

  startedAt     DateTime?
  heartbeatAt   DateTime?
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  events       InvestigationEvent[]
  evidence     EvidenceRecord[]
  productGraph ProductGraph?
  findings     Finding[]
  report       Report?

  @@index([userId])
  @@index([status])
  @@index([status, heartbeatAt])
  @@index([createdAt])
}

model InvestigationEvent {
  id               String   @id @default(cuid())
  investigationId  String
  investigation    Investigation @relation(fields: [investigationId], references: [id], onDelete: Cascade)
  sequence         Int
  eventType        String
  data             Json
  createdAt        DateTime @default(now())

  @@unique([investigationId, sequence])
  @@index([investigationId, sequence])
}

model EvidenceRecord {
  id               String   @id @default(cuid())
  investigationId  String
  investigation    Investigation @relation(fields: [investigationId], references: [id], onDelete: Cascade)
  type             String   // "screenshot" | "dom_snapshot" | "network_log" | "console_log"
  storageKey       String
  mimeType         String
  size             Int      @default(0)
  metadata         Json?
  createdAt        DateTime @default(now())

  @@index([investigationId])
}

model ProductGraph {
  id               String   @id @default(cuid())
  investigationId  String   @unique
  investigation    Investigation @relation(fields: [investigationId], references: [id], onDelete: Cascade)
  nodes            Json     // JSONB: GraphNode[]
  edges            Json     // JSONB: GraphEdge[]
  quality          Float?
  truncated        Boolean  @default(false)
  metadata         Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Finding {
  id               String   @id @default(cuid())
  investigationId  String
  investigation    Investigation @relation(fields: [investigationId], references: [id], onDelete: Cascade)
  title            String
  description      String
  severity         String   // "critical" | "high" | "medium" | "low" | "info"
  category         String   // "console_error" | "accessibility" | "dom_structure"
                           // | "network" | "visual" | "behavioral" | "functional"
  confidence       Float    @default(1.0)
  source           String   // "heuristic" | "llm" | "both"
  evidenceRefs     Json     // [{ type, id, key }]
  metadata         Json?
  isLowConfidence  Boolean  @default(false)
  fingerprint      String?
  recommendation   String?
  createdAt        DateTime @default(now())

  @@index([investigationId])
  @@index([fingerprint])
}

model Report {
  id               String   @id @default(cuid())
  investigationId  String   @unique
  investigation    Investigation @relation(fields: [investigationId], references: [id], onDelete: Cascade)
  summary          String
  overallScore     Float?
  findingCount     Int      @default(0)
  criticalCount    Int      @default(0)
  highCount        Int      @default(0)
  mediumCount      Int      @default(0)
  lowCount         Int      @default(0)
  infoCount        Int      @default(0)
  metadata         Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  shareLinks ShareLink[]
}

model ShareLink {
  id               String   @id @default(cuid())
  reportId         String
  token            String   @unique @default(cuid())
  isActive         Boolean  @default(true)
  expiresAt        DateTime?
  createdAt        DateTime @default(now())

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([token])
}

model LlmTokenUsage {
  id               String   @id @default(cuid())
  investigationId  String
  model            String
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  totalTokens      Int      @default(0)
  costUsd          Float?
  durationMs       Int      @default(0)
  createdAt        DateTime @default(now())

  @@index([investigationId])
}
